{
  "framework": "vite",
  "frameworkFlavor": "@vitejs/plugin-react",
  "version": 2,
  "buildCommand": "npm ci && npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "env": {
    "VITE_FIREBASE_API_KEY": "AIzaSyC89fa8S8jbssBaPw5zHy5FlsJGEXlfftY",
    "VITE_FIREBASE_AUTH_DOMAIN": "coonstructora-wm-mys.firebaseapp.com",
    "VITE_FIREBASE_PROJECT_ID": "coonstructora-wm-mys",
    "VITE_FIREBASE_STORAGE_BUCKET": "coonstructora-wm-mys.firebasestorage.app",
    "VITE_FIREBASE_MESSAGING_SENDER_ID": "38717234192",
    "VITE_FIREBASE_APP_ID": "1:38717234192:web:16b95baffd540c9ed2be95",
    "FIREBASE_PROJECT_ID": "coonstructora-wm-mys",
    "GEMINI_API_KEY": "AIzaSyAiexfPJ14cVk-HkM3jpGGHWhRyUltTjBg"
  },
  "regions": ["gru"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(api/.*)", "destination": "$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}