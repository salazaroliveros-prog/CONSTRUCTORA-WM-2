{
  "entities": {
    "Project": {
      "title": "Proyecto",
      "description": "Un proyecto de construcción gestionado por la empresa",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "clientName": { "type": "string" },
        "typology": { "type": "string", "enum": ["RESIDENCIAL", "COMERCIAL", "INDUSTRIAL", "OTROS"] },
        "status": { "type": "string", "enum": ["COTIZACION", "EJECUCION", "FINALIZADO"] },
        "startDate": { "type": "string", "format": "date" },
        "directCosts": { "type": "number" },
        "indirectCosts": { "type": "number" },
        "administrativeCosts": { "type": "number" },
        "personalCosts": { "type": "number" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "typology", "status", "ownerId"]
    },
    "WarehouseItem": {
      "title": "Ítem de Almacén",
      "description": "Material o herramienta en inventario",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cat": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "location": { "type": "string" },
        "minStock": { "type": "number" },
        "lastEntry": { "type": "string", "format": "date" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "stock", "minStock", "ownerId"]
    },
    "Client": {
      "title": "Cliente",
      "description": "Información del cliente para CRM",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "ownerId"]
    },
    "StaffMember": {
      "title": "Miembro del Personal",
      "description": "Empleado o contratista asignado a obras",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "specialty": { "type": "string" },
        "assignedProject": { "type": "string" },
        "status": { "type": "string" },
        "dailyRate": { "type": "number" },
        "performance": { "type": "number" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "ownerId"]
    },
    "Supplier": {
      "title": "Proveedor",
      "description": "Proveedor de materiales o servicios",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "contact": { "type": "string" },
        "email": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string" },
        "lastOrder": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "ownerId"]
    },
    "Transaction": {
      "title": "Transacción",
      "description": "Un movimiento contable de ingreso o gasto",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "qty": { "type": "number" },
        "unitCost": { "type": "number" },
        "type": { "type": "string", "enum": ["INGRESO", "GASTO"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "itemId": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["amount", "type", "category", "date", "ownerId"]
    },
    "Log": {
      "title": "Registro de Bitácora",
      "description": "Un registro de actividad o avance en obra",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "msg": { "type": "string" },
        "type": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["msg", "ownerId"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Colección de proyectos de construcción"
    },
    "/inventory/{itemId}": {
      "schema": "WarehouseItem",
      "description": "Inventario de materiales y equipos"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Base de datos de clientes"
    },
    "/staff/{staffId}": {
      "schema": "StaffMember",
      "description": "Nómina y personal de obra"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Registro de proveedores estratégicos"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Registro de movimientos financieros, facturas e ingresos"
    },
    "/logs/{logId}": {
      "schema": "Log",
      "description": "Bitácora de avances y eventos"
    }
  }
}
