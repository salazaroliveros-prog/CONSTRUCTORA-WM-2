rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Helpers ──────────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDoc() {
      return signedIn() && resource.data.ownerId == request.auth.uid;
    }

    function ownsIncomingDoc() {
      return signedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    // ─── Colecciones principales con ownerId ──────────────────────────────────
    match /projects/{docId} {
      allow read, update, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
    }

    match /clients/{docId} {
      allow read, update, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
    }

    match /staff/{docId} {
      allow read, update, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
    }

    match /suppliers/{docId} {
      allow read, update, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
    }

    match /inventory/{docId} {
      allow read, update, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
    }

    // ─── Transacciones con validación FK opcional ────────────────────────────
    match /transactions/{docId} {
      allow read, update, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      // Nota: Firestore rules NO validan FK de forma confiable contra
      // otras colecciones (exists() no cruza documentos con ownerId).
      // La validación FK se hace en firestoreService.ts del lado cliente.
    }

    // ─── PurchaseOrders con validación FK de proyecto ────────────────────────
    match /purchaseOrders/{docId} {
      allow read, update, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
    }

    // ─── Logs (bitácora) — solo admin puede eliminar ─────────────────────────
    match /logs/{docId} {
      allow read: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      allow update: if ownsExistingDoc();
      allow delete: if isAdmin() && ownsExistingDoc();
    }

    // ─── Payrolls (sensibles) ────────────────────────────────────────────────
    match /payrolls/{docId} {
      allow read, update, delete: if isAdmin() || ownsExistingDoc();
      allow create: if ownsIncomingDoc();
    }

    // ─── UserSettings — usa uid del documento ────────────────────────────────
    match /userSettings/{userId} {
      allow read, update, delete: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
    }

    // ─── Diagnóstico ──────────────────────────────────────────────────────────
    match /_diagnostico/{docId} {
      allow read, update, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
    }

    // ─── Denegar todo lo demás ───────────────────────────────────────────────
    match /{collection}/{docId} {
      allow read, write: if false;
    }
  }
}
