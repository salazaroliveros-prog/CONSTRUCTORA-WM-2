rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDoc() {
      return signedIn() && resource.data.ownerId == request.auth.uid;
    }

    function ownsIncomingDoc() {
      return signedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /{document=**} {
      allow read, update, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
    }

    match /_diagnostico/{docId} {
      allow read, update, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
    }
  }
}
