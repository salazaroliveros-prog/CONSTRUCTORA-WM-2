// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/javascript-node-postgres
{
	"name": "Node.js & PostgreSQL",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"features": {
		"ghcr.io/flexwie/devcontainer-features/op:1": {},
		"ghcr.io/wxw-matt/devcontainer-features/command_runner:0": {},
		"ghcr.io/juan-ayala/devcontainer-features/aem-sdk:1": {},
		"ghcr.io/devcontainers-extra/features/act:1": {},
		"ghcr.io/jajera/features/agentcore-cli:1": {},
		"ghcr.io/rails/devcontainer/features/activestorage:1": {},
		"ghcr.io/devcontainer-config/features/dot-config:4": {},
		"ghcr.io/wcgomes/devcontainer-features/agency-agents:0": {},
		"ghcr.io/wcgomes/devcontainer-features/agents-workspace:0": {},
		"ghcr.io/postfinance/devcontainer-features/dotnet:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"Vue.volar",
				"Oracle.mysql-shell-for-vs-code",
				"keploy.keployio",
				"kilocode.Kilo-Code"
			]
		}
	}

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// This can be used to network with other containers or with the host.
	// "forwardPorts": [3000, 5432],

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "yarn install",

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
